{
  "version": 2,
  "cleanUrls": true,
  "outputDirectory": "public",
  "functions": {
    "api/server.js": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/server" },
    { "source": "/restaurants/(.*)", "destination": "/api/server" },
    { "source": "/restaurants", "destination": "/api/server" },
    { "source": "/db-test", "destination": "/api/server" }
  ]
}
